# ───── Common Settings ──────────────────────────────────────────
DEFAULT_LOCALE=ru              # Default language for name_loc translation
API_KEYS=somekey1,somekey2     # Comma-separated list of valid API keys
API_PREFIX=/api                # Prefix for all API routes
PORT=8001                      # Port to run the FastAPI server on
DEBUG_MODE=true                # Enable debug logging and temp file saving
REQUIRE_AUTH=true              # If true, endpoints require a valid API key via Authorization header

# ───── OpenAI API ───────────────────────────────────────────────
OPENAI_API_KEY=AIzaSyB-idz2hxaxnUaoCJUrzBSgq-uzw2Gdw1s        # Your OpenAI secret API key
OPENAI_API_BASE=https://api.openai.com/v1/chat/completions  # OpenAI endpoint

OPENAI_TEXT_MODEL=gpt-4o       # OpenAI model used for text + structured output
OPENAI_IMAGE_MODEL=gpt-4o      # Vision-capable model (gpt-4o supports images)
OPENAI_AUDIO_MODEL=whisper-1   # Whisper model for transcription

# ───── Vision Inference ─────────────────────────────────────────
IMAGE_MAX_TOKENS=512           # Max tokens for vision output
IMAGE_DETAIL=high              # Image detail level: 'auto', 'low', 'high'
IMAGE_TEMPERATURE=0.4          # Temperature for image description output

# ───── Text Inference ───────────────────────────────────────────
TEXT_MAX_TOKENS=512            # Max tokens for structured text output
TEXT_TEMPERATURE=0.7           # Temperature for chat completions
TEXT_PRESENCE_PENALTY=0.0      # Penalty for introducing new topics
TEXT_FREQUENCY_PENALTY=0.0     # Penalty for repetition

# ───── Audio Inference ──────────────────────────────────────────
AUDIO_TEMPERATURE=0.0          # Temperature for Whisper transcription
